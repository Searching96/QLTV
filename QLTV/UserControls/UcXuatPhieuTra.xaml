<UserControl x:Class="QLTV.UserControls.UcXuatPhieuTra"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:QLTV.UserControls"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="450">
    <Border Background="White">
        <Grid Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0"
                  x:Name="PhieuTraContent"
                  Margin="25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0">
                    <TextBlock Grid.Row="0"
                               Background="Transparent"
                               Foreground="Black"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="25"
                               FontWeight="Medium"
                               Text="PHIẾU TRẢ" />
                    <Separator Grid.Row="0"
                               VerticalAlignment="Bottom" />
                    <TextBlock x:Name="tb_DocGia"
                               Style="{StaticResource MaterialDesignBody1TextBlock}">
                    </TextBlock>
                    <TextBlock Style="{StaticResource MaterialDesignBody1TextBlock}">
                        <Run Text="Ngày trả : " />
                        <Run Text="{Binding NgayTra, StringFormat={}{0:dd/MM/yyyy HH:mm:ss}}" />
                    </TextBlock>
                    <TextBlock x:Name="tb_SLSach"
                               Style="{StaticResource MaterialDesignBody1TextBlock}">
                    </TextBlock>
                </StackPanel>
                <DataGrid ItemsSource="{Binding CTPHIEUTRA}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          BorderThickness="2"
                          BorderBrush="Gray"
                          Grid.Row="1"
                          materialDesign:DataGridAssist.CellPadding="5"
                          Style="{StaticResource MaterialDesignDataGrid}">
                    <DataGrid.Columns>
                        <materialDesign:DataGridTextColumn Header="Tên sách"
                                                           Binding="{Binding IDSachNavigation.IDTuaSachNavigation.TenTuaSach}" />
                        <materialDesign:DataGridTextColumn Header="Số ngày mượn"
                                                           Binding="{Binding SoNgayMuon}" />
                        <materialDesign:DataGridTextColumn Header="Tiền phạt"
                                                           Binding="{Binding TienPhat, StringFormat=N0}" />
                        <materialDesign:DataGridTextColumn Header="Tình trạng"
                                                           Binding="{Binding IDTinhTrangTraNavigation.TenTinhTrang}" />
                    </DataGrid.Columns>
                </DataGrid>
                <TextBlock x:Name="tb_TongTienPhat"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Bottom"
                           Grid.Row="3"
                           Style="{StaticResource MaterialDesignBody1TextBlock}">
                </TextBlock>
            </Grid>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="10,-20,10,10">
                <Button Margin="5,5,5,0"
                        Content="In phiếu"
                        Foreground="White"
                        Click="btnInPhieu_Click" />
                <Button Margin="5,5,5,0"
                        Content="Thoát"
                        Foreground="White"
                        Click="btnThoat_Click" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
