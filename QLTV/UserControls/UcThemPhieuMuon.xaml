<UserControl x:Class="QLTV.UserControls.UcThemPhieuMuon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QLTV.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Thêm phiếu mượn" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

        <!-- Reader Selection -->
        <Grid Grid.Row="1" HorizontalAlignment="Left" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ComboBox x:Name="cboDocGia" 
                      Grid.Column="0"
                      Margin="0,0,15,0"
                      DisplayMemberPath="IDTaiKhoanNavigation.TenTaiKhoan"
                      SelectedValuePath="ID"
                      IsEditable="True"
                      Style="{StaticResource ModernComboBox}"
                      IsTextSearchEnabled="True"
                      VerticalAlignment="Center"
                      IsSynchronizedWithCurrentItem="False"
                      Width="300" HorizontalAlignment="Left"
                      materialDesign:HintAssist.Hint="Chọn độc giả"
                      materialDesign:HintAssist.FloatingScale="0.8"
                      SelectionChanged="cboDocGia_SelectionChanged">
            </ComboBox>
            <materialDesign:PackIcon Kind="AlertCircleOutline"
                                     x:Name="icDocGiaError"
                        Style="{StaticResource Warning}"/>
        </Grid>
        <!-- Search Section -->
        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Tìm kiếm sách:" Margin="0,0,0,5"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBox x:Name="txtSearchBook" 
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.Hint="Nhập thông tin sách"
                         TextChanged="txtSearchBook_TextChanged"
                         Margin="0,0,10,0"/>
                
                <ComboBox Grid.Column="1" x:Name="cboSearchType" Width="120" 
                          SelectedIndex="0"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}">
                    <ComboBoxItem Content="Tất cả"/>
                    <ComboBoxItem Content="Mã sách"/>
                    <ComboBoxItem Content="Tên sách"/>
                    <ComboBoxItem Content="Thể loại"/>
                    <ComboBoxItem Content="Tác giả"/>
                </ComboBox>
            </Grid>
        </StackPanel>

        <!-- Available Books -->
        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <TextBlock Text="Sách có sẵn:" FontWeight="Bold"/>
            <DataGrid Grid.Row="1" x:Name="dgAvailableBooks" 
                      AutoGenerateColumns="False" 
                      SelectionMode="Extended"
                      IsReadOnly="True"
                      Padding="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã sách" Binding="{Binding MaSach}" Width="2*"/>
                    <DataGridTextColumn Header="Tên sách" Binding="{Binding TuaSach}" Width="4*"/>
                    <DataGridTextColumn Header="Tác giả" Binding="{Binding DSTacGia}" Width="3*"/>
                    <DataGridTextColumn Header="Thể loại" Binding="{Binding DSTheLoai}" Width="3*"/>
                    <DataGridTextColumn Header="Tình trạng" 
                                    Binding="{Binding Book.IDTinhTrangNavigation.TenTinhTrang}" 
                                    IsReadOnly="True"
                                    Width="2*"/>
                    <DataGridTextColumn Header="Hạn mượn tối đa (tuần)" Binding="{Binding HanMuonToiDa}" Width="4*"/>
                    <DataGridTemplateColumn Width="Auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button ToolTip="Chọn" 
                                        Click="btnSelectBook_Click"
                                        DataContext="{Binding}">
                                    <materialDesign:PackIcon Kind="BookAdd"
                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Foreground="White" Background="Transparent" Width="20" Height="20"
                                        ToolTipService.InitialShowDelay="0"/>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Selected Books Header -->
        <TextBlock Grid.Row="4" Text="Sách đã chọn:" FontWeight="Bold" Margin="0,0,0,5"/>

        <!-- Selected Books -->
        <DataGrid Grid.Row="5" x:Name="dgSelectedBooks" 
                  AutoGenerateColumns="False" 
                  Margin="0,0,0,10"
                  Padding="0"
                  CanUserAddRows="False">
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell" BasedOn="{StaticResource MaterialDesignDataGridCell}">
                    <Setter Property="Padding" Value="5,15,5,0"/>
                    <!--<Setter Property="VerticalAlignment" Value="Stretch"/>
                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>-->
                </Style>
            </DataGrid.CellStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã sách" Binding="{Binding MaSach}" IsReadOnly="True" Width="2*"/>
                <DataGridTextColumn Header="Tên sách" 
                                    Binding="{Binding IDTuaSachNavigation.TenTuaSach}" 
                                    IsReadOnly="True"
                                    Width="3*"/>
                <DataGridTextColumn Header="Tác giả" 
                                    Binding="{Binding DSTacGia}" 
                                    Width="3*"
                                    IsReadOnly="True"/>
                <DataGridTextColumn Header="Thể loại" 
                                    Binding="{Binding DSTheLoai}" 
                                    IsReadOnly="True"
                                    Width="3*"/>
                <DataGridTextColumn Header="Tình trạng" 
                                    Binding="{Binding Book.IDTinhTrangNavigation.TenTinhTrang}" 
                                    IsReadOnly="True"
                                    Width="2*"/>
                <DataGridTextColumn Header="Hạn trả" 
                                    Binding="{Binding CustomReturnDate, StringFormat=dd/MM/yyyy}" 
                                    IsReadOnly="True"
                                    Width="3*"/>
                <DataGridTemplateColumn Header="Số tuần mượn" Width="2*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid>
                                <TextBlock
                                Text="{Binding CustomBorrowWeeks}"
                                    Margin="0,0,0,15"
                                    Padding="5,0,0,0"/>
                                <!--<materialDesign:PackIcon Style="{StaticResource Warning}"/>-->
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <Grid >
                                <TextBox
                                    AcceptsReturn="False"
                                    Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                    Foreground="{DynamicResource SecondaryHueMidBrush}"
                                    materialDesign:ValidationAssist.HorizontalAlignment="Left"
                                    Padding="0"
                                    materialDesign:ValidationAssist.Background="Transparent"
                                    Margin="0,0,0,15"
                                    Text = "{Binding CustomBorrowWeeks, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                />
                                <!--<materialDesign:PackIcon Kind="AlertCircleOutline"
                                    Style="{StaticResource Warning}"/>-->
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button ToolTip="Xóa" Click="btnRemoveBook_Click">
                                <materialDesign:PackIcon Kind="BookRemove"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Foreground="White" Background="Transparent" Width="20" Height="20"
                                    ToolTipService.InitialShowDelay="0"/>
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button ToolTip="Lưu" Width="100" Margin="0,0,10,0" Click="btnSave_Click">
                <materialDesign:PackIcon Kind="BookArrowDownOutline"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Foreground="White" Background="Transparent" Width="20" Height="20"
                    ToolTipService.InitialShowDelay="0"/>
            </Button>
            <Button ToolTip="Hủy" Width="100" Click="btnCancel_Click">
                <materialDesign:PackIcon Kind="CancelCircleOutline"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Foreground="White" Background="Transparent" Width="20" Height="20"
                        ToolTipService.InitialShowDelay="0"/>
            </Button>
        </StackPanel>
    </Grid>
</UserControl> 